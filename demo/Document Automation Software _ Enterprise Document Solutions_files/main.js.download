				x: -30,
				opacity: 0,
			});

			gsap.to(btt, {
				x: 0,
				opacity: 1,
				ease: 'sine',
				scrollTrigger: {
					trigger: "body",
					start: "top -40%",
					end: "top -40%",
					toggleActions: "play none reverse none"
				}
			});
		}
    }

