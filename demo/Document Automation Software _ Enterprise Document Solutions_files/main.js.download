    /***************************

    color variables

    ***************************/
    var variables = {
        "accentColor": 'rgba(255, 152, 0, 1)',
        "darkColor": '#000',
        "lightColor" : '#fff'
    }

    /* Custom Colors */
    if ( $('.mil-wrapper').data('dark-color') ) {
        variables.darkColor = $('.mil-wrapper').data('dark-color');
    }
    if ( $('.mil-wrapper').data('accent-color') ) {
        variables.accentColor = $('.mil-wrapper').data('accent-color');
